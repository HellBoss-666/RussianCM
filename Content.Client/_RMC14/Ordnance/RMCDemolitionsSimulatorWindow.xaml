<cc:RMCDemolitionsSimulatorWindow
    xmlns="https://spacestation14.io"
    xmlns:cc="clr-namespace:Content.Client._RMC14.Ordnance"
    Title="Demolitions Simulator"
    MinSize="380 300"
    SetSize="380 300">
    <BoxContainer Orientation="Vertical" Margin="8">
        <Label Name="InstructionLabel" Access="Public"
               Text="Hold a chembomb casing in your active hand and press Simulate."
               HorizontalAlignment="Center"
               Margin="0 0 0 6" />
        <Button Name="SimulateButton" Access="Public"
                Text="Simulate"
                HorizontalAlignment="Center"
                Margin="0 0 0 4" />
        <Label Name="CooldownLabel" Access="Public"
               HorizontalAlignment="Center"
               Visible="False"
               Margin="0 0 0 6" />
        <Control MinSize="0 4" />
        <ScrollContainer HScrollEnabled="False" HorizontalExpand="True" VerticalExpand="True">
            <RichTextLabel Name="ResultLabel" Access="Public" HorizontalExpand="True" />
        </ScrollContainer>
    </BoxContainer>
</cc:RMCDemolitionsSimulatorWindow>
